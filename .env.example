# PostgreSQL connection string (Neon free tier)
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Server port (optional, defaults to 8080)
GIN_MODE=debug
PORT=8080

# Origenes CORS permitidos, separados por coma (opcional)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
